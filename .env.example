# Agent Coordinator — Environment Variables
# Copy to .env and fill in values as needed. All vars have safe defaults.

# ── TimescaleDB (telemetry) — optional ───────────────────────────────
# Used for long-term telemetry persistence. If not set, telemetry is buffered to SQLite only.
# Start: docker compose -f docker-compose.telemetry.yml up -d timescaledb
TSDB_URL=postgresql://coordinator:coordinator_dev@localhost:5433/telemetry
TSDB_PASSWORD=coordinator_dev

# ── Qdrant (semantic memory) — optional ──────────────────────────────
# Used for semantic search across agent notes, code, docs, and issues.
# Start: docker compose -f docker-compose.telemetry.yml up -d qdrant
QDRANT_URL=http://localhost:6333

# ── Storage backend ────────────────────────────────────────────────────
# "file" = file-based (default, no extra deps)
# "sqlite" = SQLite-backed (recommended for production swarms)
STORAGE_BACKEND=file

# ── Telemetry ──────────────────────────────────────────────────────────
TELEMETRY_ENABLED=true
TELEMETRY_BUFFER_TTL_HOURS=168

# ── Workspace ─────────────────────────────────────────────────────────
# Optional: override workspace root for MCP server
# WORKSPACE_ROOT=/path/to/project
